{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "types": ["@cloudflare/workers-types"],
    // dev/ scripts run directly under Node (>= 23 strips types natively),
    // where ESM imports need explicit .ts extensions. Legal because noEmit.
    "allowImportingTsExtensions": true
  },
  "include": ["src", "test", "dev"]
}
