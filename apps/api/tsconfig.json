{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // Runtime and Env types come from worker-configuration.d.ts, generated by
    // `pnpm types` (ADR-136) — pinned to wrangler.jsonc's compatibility date,
    // replacing the @cloudflare/workers-types package. Empty `types` keeps
    // stray @types packages out of the Worker's type space.
    "types": [],
    // dev/ scripts run directly under Node (pinned in .npmrc), where ESM
    // imports need explicit .ts extensions. Legal because noEmit.
    "allowImportingTsExtensions": true
  },
  "include": ["worker-configuration.d.ts", "src", "test", "dev"]
}
